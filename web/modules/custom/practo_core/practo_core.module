/**
 * Implements hook_help().
 * 
 * Provides help text for the module.
 */
function practo_core_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.practo_core':
      return '<p>' . t('Practo Core module provides healthcare appointment booking functionality.') . '</p>';
  }
}

