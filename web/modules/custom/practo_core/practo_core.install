<?php

/**
 * @file
 * Install, update and uninstall functions for Practo Core module.
 */

use Drupal\node\Entity\NodeType;
use Drupal\field\Entity\FieldStorageConfig;
use Drupal\field\Entity\FieldConfig;
use Drupal\Core\Field\BaseFieldDefinition;
use Drupal\Core\Entity\Entity\EntityFormDisplay;

/**
 * Implements hook_install().
 * 
 * Creates custom content types, fields, and initial configuration
 * when the module is installed.
 */
function practo_core_install() {
  // Create Doctor content type
  _practo_core_create_doctor_content_type();
  
  // Create Appointment content type
  _practo_core_create_appointment_content_type();
  
  // Create user type field
  _practo_core_create_user_type_field();
  
  // Set permissions
  _practo_core_set_permissions();

  // Ensure form display has required widgets.
  _practo_core_configure_doctor_form_display();
  
  // Display success message
  \Drupal::messenger()->addStatus(t('Practo Core module installed successfully. Doctor and Appointment content types created.'));
}


/**
 * Creates Doctor content type with all fields.
 */
function _practo_core_create_doctor_content_type() {
