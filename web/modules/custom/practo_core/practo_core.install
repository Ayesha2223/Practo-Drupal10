      ],
      'required' => TRUE,
    ],
    'field_patient_name' => [
      'type' => 'string',
      'label' => 'Patient Full Name',
      'settings' => ['max_length' => 255],
      'required' => TRUE,
    ],
    'field_patient_age' => [
      'type' => 'integer',
      'label' => 'Patient Age',
      'settings' => ['min' => 1, 'max' => 120],
      'required' => TRUE,
    ],
    'field_patient_gender' => [
      'type' => 'list_string',
      'label' => 'Gender',
      'settings' => [
        'allowed_values' => [
          'male' => 'Male',
          'female' => 'Female',
          'other' => 'Other',
        ],
      ],
      'required' => TRUE,
    ],
    'field_contact_number' => [
      'type' => 'string',
      'label' => 'Contact Number',
      'settings' => ['max_length' => 15],
      'required' => TRUE,
    ],
    'field_reason_visit' => [
      'type' => 'text_long',
      'label' => 'Reason for Visit',
      'required' => TRUE,
    ],
    'field_appointment_status' => [
      'type' => 'list_string',
      'label' => 'Status',
      'settings' => [
        'allowed_values' => [
          'pending' => 'Pending',
