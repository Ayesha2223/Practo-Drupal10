/**
 * Creates user type field for user entity.
 */
function _practo_core_create_user_type_field() {
  $field_storage = FieldStorageConfig::loadByName('user', 'field_user_type');
  
  if (!$field_storage) {
    $field_storage = FieldStorageConfig::create([
      'field_name' => 'field_user_type',
      'entity_type' => 'user',
      'type' => 'list_string',
      'cardinality' => 1,
      'settings' => [
        'allowed_values' => [
          'patient' => 'Patient',
          'doctor' => 'Doctor',
          'admin' => 'Admin',
        ],
      ],
    ]);
    $field_storage->save();
  }
  
  $field = FieldConfig::loadByName('user', 'user', 'field_user_type');
  
  if (!$field) {
    $field = FieldConfig::create([
      'field_storage' => $field_storage,
      'bundle' => 'user',
      'label' => 'User Type',
      'required' => TRUE,
      'default_value' => [['value' => 'patient']],
    ]);
    $field->save();
  }

  // Create additional user fields for registration
  _practo_core_create_user_additional_fields();
}

