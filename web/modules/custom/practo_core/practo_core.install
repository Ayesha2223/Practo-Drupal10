  $doctor_type = NodeType::create([
    'type' => 'doctor',
    'name' => 'Doctor',
    'description' => 'Doctor profiles with specialization, qualifications, and availability',
    'display_submitted' => FALSE,
  ]);
  $doctor_type->save();
  
  // Create fields
  $fields = [
    'field_specialization' => [
      'type' => 'list_string',
      'label' => 'Specialization',
      'settings' => [
        'allowed_values' => [
          'cardiology' => 'Cardiologist',
          'dermatology' => 'Dermatologist',
          'pediatrics' => 'Pediatrician',
          'orthopedics' => 'Orthopedic Surgeon',
          'general' => 'General Physician',
          'gynecology' => 'Gynecologist',
          'neurology' => 'Neurologist',
          'psychiatry' => 'Psychiatrist',
          'dentistry' => 'Dentist',
          'ophthalmology' => 'Ophthalmologist',
        ],
      ],
      'required' => TRUE,
    ],
    'field_qualification' => [
      'type' => 'string',
      'label' => 'Qualification',
      'settings' => ['max_length' => 255],
      'required' => TRUE,
    ],
    'field_experience_years' => [
      'type' => 'integer',
      'label' => 'Years of Experience',
      'settings' => ['min' => 0, 'max' => 60],
      'required' => TRUE,
    ],
    'field_consultation_fee' => [
      'type' => 'decimal',
      'label' => 'Consultation Fee (₹)',
      'settings' => ['precision' => 10, 'scale' => 2],
      'required' => TRUE,
    ],
    'field_profile_photo' => [
      'type' => 'image',
      'label' => 'Profile Photo',
      'storage_settings' => [
        'uri_scheme' => 'public',
      ],
      'settings' => [
        'file_directory' => 'doctors/photos',
        'max_filesize' => '2 MB',
        'file_extensions' => 'png jpg jpeg',
        'alt_field' => TRUE,
        'alt_field_required' => FALSE,
        'title_field' => TRUE,
        'title_field_required' => FALSE,
      ],
      'required' => FALSE,
    ],
    'field_clinic_name' => [
      'type' => 'string',
      'label' => 'Clinic Name',
      'settings' => ['max_length' => 255],
      'required' => TRUE,
    ],
    'field_clinic_address' => [
      'type' => 'string_long',
      'label' => 'Clinic Address',
      'required' => TRUE,
    ],
    'field_city' => [
      'type' => 'string',
      'label' => 'City',
      'settings' => ['max_length' => 100],
      'required' => TRUE,
    ],
    'field_phone' => [
      'type' => 'string',
      'label' => 'Phone Number',
      'settings' => ['max_length' => 15],
      'required' => TRUE,
    ],
    'field_email' => [
      'type' => 'email',
      'label' => 'Email Address',
      'required' => TRUE,
    ],
    'field_available_days' => [
      'type' => 'list_string',
      'label' => 'Available Days',
      'cardinality' => -1,
      'settings' => [
        'allowed_values' => [
          'monday' => 'Monday',
          'tuesday' => 'Tuesday',
          'wednesday' => 'Wednesday',
          'thursday' => 'Thursday',
          'friday' => 'Friday',
          'saturday' => 'Saturday',
          'sunday' => 'Sunday',
        ],
      ],
      'required' => TRUE,
    ],
    'field_consultation_hours' => [
      'type' => 'string',
      'label' => 'Consultation Hours',
      'settings' => ['max_length' => 100],
      'default_value' => '09:00 AM - 05:00 PM',
      'required' => TRUE,
    ],
    'field_about_doctor' => [
      'type' => 'text_long',
      'label' => 'About Doctor',
      'required' => FALSE,
    ],
    'field_languages_spoken' => [
      'type' => 'string',
      'label' => 'Languages Spoken',
      'settings' => ['max_length' => 255],
      'default_value' => 'English, Hindi',
      'required' => FALSE,
    ],
  ];
  
  foreach ($fields as $field_name => $field_info) {
    _practo_core_create_field($field_name, 'node', 'doctor', $field_info);
  }

  _practo_core_configure_doctor_form_display();
  
  \Drupal::messenger()->addStatus(t('Doctor content type created with custom fields.'));
}

/**
 * Ensures doctor node form display shows key fields including profile photo.
 */
function _practo_core_configure_doctor_form_display() {
  // Configure default form display for doctor content type.
  $form_display = EntityFormDisplay::load('node.doctor.default');
  if (!$form_display) {
    $form_display = EntityFormDisplay::create([
      'targetEntityType' => 'node',
      'bundle' => 'doctor',
      'mode' => 'default',
      'status' => TRUE,
    ]);
  }

  // Only set widgets for fields that actually exist.
  $field_definitions = \Drupal::service('entity_field.manager')->getFieldDefinitions('node', 'doctor');

  if (isset($field_definitions['field_profile_photo'])) {
    $form_display->setComponent('field_profile_photo', [
      'type' => 'image_image',
      'weight' => 2,
      'settings' => [
        'progress_indicator' => 'throbber',
        'preview_image_style' => 'thumbnail',
      ],
    ]);
  }

  $form_display->save();
}

