          '09:30' => '09:30 AM',
          '10:00' => '10:00 AM',
          '10:30' => '10:30 AM',
          '11:00' => '11:00 AM',
          '11:30' => '11:30 AM',
          '12:00' => '12:00 PM',
          '14:00' => '02:00 PM',
          '14:30' => '02:30 PM',
          '15:00' => '03:00 PM',
          '15:30' => '03:30 PM',
          '16:00' => '04:00 PM',
          '16:30' => '04:30 PM',
          '17:00' => '05:00 PM',
