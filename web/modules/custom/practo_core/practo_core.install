/**
 * Helper function to create fields.
 */
function _practo_core_create_field($field_name, $entity_type, $bundle, $field_info) {
  // Check if field storage exists
  $field_storage = FieldStorageConfig::loadByName($entity_type, $field_name);
  
  if (!$field_storage) {
    $storage_settings = $field_info['storage_settings'] ?? [];
    if (($field_info['type'] ?? '') === 'image') {
      $storage_settings += ['uri_scheme' => 'public'];
    }
    $field_storage = FieldStorageConfig::create([
      'field_name' => $field_name,
      'entity_type' => $entity_type,
      'type' => $field_info['type'],
      'cardinality' => isset($field_info['cardinality']) ? $field_info['cardinality'] : 1,
      'settings' => $storage_settings,
    ]);
    $field_storage->save();
  }
  
  // Check if field instance exists
  $field = FieldConfig::loadByName($entity_type, $bundle, $field_name);
  
  if (!$field) {
    $instance_settings = $field_info['settings'] ?? [];
    $field = FieldConfig::create([
      'field_storage' => $field_storage,
      'bundle' => $bundle,
      'label' => $field_info['label'],
      'required' => isset($field_info['required']) ? $field_info['required'] : FALSE,
      'default_value' => isset($field_info['default_value']) ? [['value' => $field_info['default_value']]] : NULL,
      'settings' => $instance_settings,
    ]);
    $field->save();
  }
}

/**
 * Sets default permissions.
 */
function _practo_core_set_permissions() {
  // Create custom roles
  _practo_core_create_user_roles();
  
  $roles = ['authenticated', 'patient', 'doctor', 'admin'];
  
  foreach ($roles as $role_name) {
    $role = \Drupal\user\Entity\Role::load($role_name);
    
    if ($role) {
      // Base permissions for all authenticated users
      $role->grantPermission('view doctor content');
      
      // Patient-specific permissions
      if ($role_name === 'patient' || $role_name === 'authenticated') {
        $role->grantPermission('create appointment content');
        $role->grantPermission('edit own appointment content');
        $role->grantPermission('delete own appointment content');
        $role->grantPermission('view own appointment content');
      }
      
      // Doctor-specific permissions
      if ($role_name === 'doctor' || $role_name === 'admin') {
        $role->grantPermission('view own doctor content');
        $role->grantPermission('edit own doctor content');
        $role->grantPermission('view appointment content');
        $role->grantPermission('edit appointment content');
      }
      
      // Admin-specific permissions
      if ($role_name === 'admin') {
        $role->grantPermission('administer nodes');
        $role->grantPermission('create doctor content');
        $role->grantPermission('edit any doctor content');
        $role->grantPermission('delete any doctor content');
        $role->grantPermission('administer users');
        $role->grantPermission('access user profiles');
      }
      
      $role->save();
    }
  }
}

/**
 * Creates custom user roles.
 */
function _practo_core_create_user_roles() {
  // Create patient role
  $patient_role = \Drupal\user\Entity\Role::load('patient');
  if (!$patient_role) {
    $patient_role = \Drupal\user\Entity\Role::create(['id' => 'patient', 'label' => 'Patient']);
    $patient_role->save();
  }
  
  // Create doctor role
  $doctor_role = \Drupal\user\Entity\Role::load('doctor');
  if (!$doctor_role) {
    $doctor_role = \Drupal\user\Entity\Role::create(['id' => 'doctor', 'label' => 'Doctor']);
    $doctor_role->save();
  }
  
  // Create admin role
  $admin_role = \Drupal\user\Entity\Role::load('admin');
  if (!$admin_role) {
    $admin_role = \Drupal\user\Entity\Role::create(['id' => 'admin', 'label' => 'Admin']);
    $admin_role->save();
  }
}

/**
 * Implements hook_uninstall().
 * 
 * Cleans up when module is uninstalled.
 */
function practo_core_uninstall() {
  // Delete content types and their content
  $content_types = ['doctor', 'appointment'];
  
  foreach ($content_types as $type) {
    // Delete all nodes of this type
    $nids = \Drupal::entityQuery('node')
      ->condition('type', $type)
      ->accessCheck(FALSE)
      ->execute();
    
    if (!empty($nids)) {
      $nodes = \Drupal\node\Entity\Node::loadMultiple($nids);
      foreach ($nodes as $node) {
        $node->delete();
      }
    }
    
    // Delete the content type
    $content_type = NodeType::load($type);
    if ($content_type) {
      $content_type->delete();
    }
  }
  
  \Drupal::messenger()->addStatus(t('Practo Core module uninstalled. All data removed.'));
}