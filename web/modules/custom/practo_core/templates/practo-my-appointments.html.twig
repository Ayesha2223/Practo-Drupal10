{#
/**
 * @file
 * Template for my appointments page.
 *
 * Available variables:
 * - upcoming: Array of upcoming appointments
 * - past: Array of past appointments
 */
#}

<div class="my-appointments-page">
  
  <h1>My Appointments</h1>
  
  <div class="appointments-tabs">
    <button class="tab-btn active" data-tab="upcoming">
      Upcoming ({{ upcoming|length }})
    </button>
    <button class="tab-btn" data-tab="past">
      Past ({{ past|length }})
    </button>
  </div>
  
  <div class="tab-content active" id="upcoming">
    <h2>Upcoming Appointments</h2>
    
    {% if upcoming is empty %}
      <div class="empty-state">
        <i class="fas fa-calendar-alt fa-3x"></i>
        <p>No upcoming appointments</p>
        <a href="{{ practo_safe_internal('/doctors') }}" class="btn btn-primary">Book Now</a>
      </div>
    {% else %}
      <div class="appointments-list">
        {% for appointment in upcoming %}
          <div class="appointment-card {{ appointment.status_class }}">
            <div class="appointment-header">
              <h3>Dr. {{ appointment.doctor_name }}</h3>
              <span class="status-badge {{ appointment.status_class }}">
                {{ appointment.status }}
              </span>
            </div>
            
            <div class="appointment-details">
              <p><strong>Booking ID:</strong> {{ appointment.booking_id }}</p>
              <p><strong>Specialization:</strong> {{ appointment.doctor_specialization }}</p>
              <p><strong>Clinic:</strong> {{ appointment.clinic_name }}</p>
              <p><strong>Date:</strong> {{ appointment.date }}</p>
              <p><strong>Time:</strong> {{ appointment.time }}</p>
              <p><strong>Reason:</strong> {{ appointment.reason }}</p>
            </div>
            
            {% if appointment.cancel_link %}
              <div class="appointment-actions">
                {{ appointment.cancel_link }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  
  <div class="tab-content" id="past">
    <h2>Past Appointments</h2>
    
    {% if past is empty %}
      <div class="empty-state">
        <i class="fas fa-history fa-3x"></i>
        <p>No past appointments</p>
      </div>
    {% else %}
      <div class="appointments-list">
        {% for appointment in past %}
          <div class="appointment-card past {{ appointment.status_class }}">
            <div class="appointment-header">
              <h3>Dr. {{ appointment.doctor_name }}</h3>
              <span class="status-badge {{ appointment.status_class }}">
                {{ appointment.status }}
              </span>
            </div>
            
            <div class="appointment-details">
              <p><strong>Booking ID:</strong> {{ appointment.booking_id }}</p>
              <p><strong>Date:</strong> {{ appointment.date }}</p>
              <p><strong>Time:</strong> {{ appointment.time }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  
</div>