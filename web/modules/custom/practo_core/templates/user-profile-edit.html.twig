<div class="container" style="max-width: 1100px; padding: 30px 15px;">
  <div class="card" style="border-radius: 16px; border: 1px solid #e5e7eb; box-shadow: 0 2px 12px rgba(0,0,0,.05);">
    <div class="card-body" style="padding: 18px;">
      <h1 style="margin: 0 0 8px; font-size: 26px; font-weight: 900; color: #111827;">Edit Profile</h1>
      <p style="margin: 0 0 16px; color: #6b7280;">Manage your profile information and professional details.</p>

      <div style="display:grid; gap:10px;">
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:12px;">
          <div style="color:#6b7280; font-weight:800;">Username</div>
          <div style="color:#111827; font-weight:900;">{{ user.getAccountName() }}</div>
        </div>
        <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:12px;">
          <div style="color:#6b7280; font-weight:800;">Email</div>
          <div style="color:#111827; font-weight:900;">{{ user.getEmail() }}</div>
        </div>
      </div>

      <div style="margin-top: 16px; display:flex; gap:10px; flex-wrap:wrap;">
        {% if doctor_node_id %}
          <a href="{{ practo_safe_route('entity.node.edit_form', {'node': doctor_node_id}) }}" style="display:inline-flex; padding:10px 14px; border-radius:12px; text-decoration:none; font-weight:900; background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#fff;">Edit Doctor Profile</a>
        {% endif %}
        <a href="{{ practo_safe_route('entity.user.edit_form', {'user': user.id}) }}" style="display:inline-flex; padding:10px 14px; border-radius:12px; text-decoration:none; font-weight:900; background:linear-gradient(135deg,#64748b,#475569); color:#fff;">Edit User Account</a>
        <a href="{{ practo_safe_route('practo_core.dashboard_redirect') }}" style="display:inline-flex; padding:10px 14px; border-radius:12px; text-decoration:none; font-weight:900; background:#f3f4f6; color:#111827;">Back to Dashboard</a>
      </div>
    </div>
  </div>
</div>
