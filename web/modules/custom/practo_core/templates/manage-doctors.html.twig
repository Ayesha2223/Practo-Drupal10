{#
/**
 * @file
 * Manage Doctors - Full CRUD Operations
 */
#}

<div class="manage-content-page">
  
  <div class="page-header-admin">
    <div>
      <h1><i class="fas fa-user-md"></i> Manage Doctors (CRUD)</h1>
      <p>Create, Read, Update, Delete doctor records</p>
    </div>
    <a href="{{ practo_safe_route('node.add', {'node_type': 'doctor'}) }}" class="btn btn-success btn-lg">
      <i class="fas fa-plus"></i> Add New Doctor
    </a>
  </div>
  
  {% if doctors is empty %}
    <div class="empty-state-admin">
      <i class="fas fa-inbox fa-5x"></i>
      <h3>No Doctors Found</h3>
      <p>Start by adding your first doctor</p>
      <a href="{{ practo_safe_route('node.add', {'node_type': 'doctor'}) }}" class="btn btn-primary btn-lg">Add Doctor Now</a>
    </div>
  {% else %}
    <div class="crud-table-wrapper">
      <table class="crud-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Specialization</th>
            <th>Experience</th>
            <th>Fee</th>
            <th>City</th>
            <th>Status</th>
            <th>Actions (CRUD)</th>
          </tr>
        </thead>
        <tbody>
          {% for doctor in doctors %}
            <tr>
              <td>#{{ doctor.id }}</td>
              <td><strong>Dr. {{ doctor.name }}</strong></td>
              <td>{{ doctor.specialization }}</td>
              <td>{{ doctor.experience }} years</td>
              <td>₹{{ doctor.fee }}</td>
              <td>{{ doctor.city }}</td>
              <td>
                <span class="status-badge {{ doctor.status == 'Active' ? 'active' : 'inactive' }}">
                  {{ doctor.status }}
                </span>
              </td>
              <td class="actions-cell">
                <a href="{{ doctor.view_url }}" class="action-btn-small view" title="Read/View">
                  <i class="fas fa-eye"></i>
                </a>
                <a href="{{ doctor.edit_url }}" class="action-btn-small edit" title="Update/Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <a href="{{ doctor.delete_url }}" class="action-btn-small delete" title="Delete" onclick="return confirm('Are you sure you want to delete this doctor?')">
                  <i class="fas fa-trash"></i>
                </a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    
    <div class="table-footer">
      <p>Total Records: <strong>{{ doctors|length }}</strong></p>
    </div>
  {% endif %}
  
</div>