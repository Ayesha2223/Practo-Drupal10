{#
/**
 * @file
 * Manage Health Articles - Full CRUD
 */
#}

<div class="manage-content-page">
  
  <div class="page-header-admin">
    <div>
      <h1><i class="fas fa-newspaper"></i> Manage Health Articles (CRUD)</h1>
<p>Create, Read, Update, Delete health articles</p>
</div>
<a href="{{ practo_safe_route('node.add', {'node_type': 'health_article'}) }}" class="btn btn-success btn-lg">
<i class="fas fa-plus"></i> Add New Article
</a>
  </div>
{% if articles is empty %}
<div class="empty-state-admin">
<i class="fas fa-file-alt fa-5x"></i>
<h3>No Articles Found</h3>
<p>Start by writing health articles</p>
<a href="{{ practo_safe_route('node.add', {'node_type': 'health_article'}) }}" class="btn btn-primary btn-lg">Add Article Now</a>
</div>
{% else %}
<div class="crud-table-wrapper">
<table class="crud-table">
<thead>
<tr>
<th>ID</th>
<th>Title</th>
<th>Category</th>
<th>Author</th>
<th>Created</th>
<th>Status</th>
<th>Actions (CRUD)</th>
</tr>
</thead>
<tbody>
{% for article in articles %}
<tr>
<td>#{{ article.id }}</td>
<td><strong>{{ article.title }}</strong></td>
<td>{{ article.category }}</td>
<td>{{ article.author }}</td>
<td>{{ article.created }}</td>
<td>
<span class="status-badge {{ article.status == 'Published' ? 'active' : 'inactive' }}">
{{ article.status }}
</span>
</td>
<td class="actions-cell">
<a href="{{ article.view_url }}" class="action-btn-small view" title="Read/View">
<i class="fas fa-eye"></i>
</a>
<a href="{{ article.edit_url }}" class="action-btn-small edit" title="Update/Edit">
<i class="fas fa-edit"></i>
</a>
<a href="{{ article.delete_url }}" class="action-btn-small delete" title="Delete" onclick="return confirm('Delete this article?')">
<i class="fas fa-trash"></i>
</a>
</td>
</tr>
{% endfor %}
</tbody>
</table>
</div>
<div class="table-footer">
  <p>Total Articles: <strong>{{ articles|length }}</strong></p>
</div>
{% endif %}
</div>